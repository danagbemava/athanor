{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkerExecutionRequest",
  "version": "0.1.0-scaffold",
  "type": "object",
  "required": [
    "bundle_hash",
    "seed_start",
    "run_count",
    "agent_policy",
    "execution_mode",
    "max_steps"
  ],
  "properties": {
    "bundle_hash": { "type": "string", "minLength": 1 },
    "seed_start": { "type": "integer", "minimum": 0 },
    "run_count": { "type": "integer", "minimum": 1 },
    "agent_policy": { "type": "string", "enum": ["random-v1", "scripted-v1"] },
    "scripted_choices": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    },
    "execution_mode": { "type": "string", "enum": ["optimization", "analytics"] },
    "max_steps": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}

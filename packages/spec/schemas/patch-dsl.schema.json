{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatchDSL",
  "version": "0.1.0-scaffold",
  "type": "object",
  "required": ["op", "args"],
  "properties": {
    "op": {
      "type": "string",
      "enum": [
        "INSERT_NODE",
        "REMOVE_NODE",
        "INSERT_CHANCE_NODE",

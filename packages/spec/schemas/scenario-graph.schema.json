{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScenarioGraph",
  "version": "0.1.0-scaffold",
  "type": "object",
  "required": ["id", "name", "version", "nodes", "edges"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["DecisionNode", "ChanceNode", "TerminalNode"] }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "objectives": { "type": "object" },
    "constraints": { "type": "object" },
    "stateSchema": { "type": "object" }
  },
  "additionalProperties": true
}
